                <characteristic name="AP" typeId="6abee736-f8d3-498e-97ac-a5c68445609f">4</characteristic>
                <characteristic name="Type" typeId="077c342f-d7b9-45c6-b8af-88e97cafd3a2">Fleshbane, Rending (5-6)</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <constraints>
            <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="e309-eeab-3f13-40a6" includeChildSelections="false"/>
            <constraint type="min" value="1" field="selections" scope="parent" shared="true" id="95ba-441f-19b8-9190" includeChildSelections="false"/>
          </constraints>
        </selectionEntry>
      </selectionEntries>
      <rules>
        <rule name="Preferred Enemy (Characters)" id="00bb-fbde-5afd-289d" hidden="false">
          <description>The unit can re-roll failed hits in close combat against the indicated preferred enemy.</description>
        </rule>
        <rule name="Hidden amongst the horde" id="fac1-2905-300a-1bab" hidden="false">
          <description>Before the battle begins In the Place units in reserves step, you can pick a friendly Neophyte Hybrids or Acolyte Hybrids to be the unit in which this unit is hiding. Record this information on a separate piece of paper. Do not set up this unit until it is revealed as described next. 


At the start of step 3: Resolve Melee engagement, if this model is still hidden, and the unit it has joined is in an melee engagement, it must reveal itself. When you reveal this unit, set it up within 2&quot; of the unit in which it was hidden, it must be set up so it is engaged in the combat. This model counts as having charged if its unit charged.


In addition, if the unit in which this unit is hidden in is destroyed and this model is still hidden, you must reveal this model before the last model in the unit in which it is hidden is removed from play. Place it within 2&apos;&apos; of the last model and more than 1&apos;&apos; away from enemies, if not possible place it as close to the original position without being within 1&apos;&apos; of an enemy.</description>
        </rule>
        <rule name="Priority target" id="48de-94cf-ac70-d496" hidden="false">
          <description>When this model issues a challenge, it may choose its opponent.</description>
        </rule>
      </rules>
      <constraints>
        <constraint type="max" value="1" field="selections" scope="force" shared="true" id="2331-fffe-e398-efdb" includeChildSelections="false"/>
      </constraints>
    </selectionEntry>

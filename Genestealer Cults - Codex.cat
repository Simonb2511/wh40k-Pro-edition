    <selectionEntry id="3b71-90a5-5ca2-2abc" name="The Crouchling" hidden="false" collective="false" type="upgrade">
      <profiles>
        <profile typeId="72c5eafc-75bf-4ed9-b425-78009f1efe82" id="d963-9cf6-4240-9198" name="The Crouchling" publicationId="f840-ed73-pubd1e1" page="101" hidden="false">
          <characteristics>
            <characteristic typeId="21befb24-fc85-4f52-a745-64b2e48f8228" name="Description">In close combat, a model with accompanied by the Crouchling makes two additional S4 AP- attacks with the Rending special rule. In addition, the bearer may generate one additional psychic power at the start of the game.  The Crouchling is represented by a separate miniature that will always remain as close as possible to it&apos;s master. The model itself is decorative and is always ignored for game purproses - just move it to one side if it gets in the way. Remove the Crouchling once it&apos;s master has been slain.</characteristic>
          </characteristics>
        </profile>
      </profiles>
      <constraints>
        <constraint field="selections" scope="parent" value="1" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="maxSelections" type="max"/>
        <constraint field="selections" scope="roster" value="1" percentValue="false" shared="true" includeChildSelections="true" includeChildForces="false" id="maxInRoster" type="max"/>
      </constraints>
      <costs>
        <cost typeId="points" name="pts" value="20"/>
      </costs>
    </selectionEntry>
    <selectionEntry id="57f9-ea29-4fc2-ee67" name="The Doting Throng" hidden="false" collective="false" type="upgrade">
      <rules>
        <rule id="ff8d-b084-2313-f764" name="Frenzied Devotion" publicationId="f840-ed73-pubd1e1" page="92" hidden="false">
          <description>Units from this Formation have the Zealot special rule whilst they are within 12&quot; of a friendly Magus. Furthermore, a unit that is actually joined by a Magus can re-roll failed To Hit rolls in every round of close combat, not just the first.</description>
        </rule>
        <rule id="eb99-5454-7931-3950" name="Willing Subjects" publicationId="f840-ed73-pubd1e1" page="92" hidden="false">
          <description>If a Magus targets a Neophyte Hybrid or Acolyte Hybrid unit from this Formation with a blessing psychic power, be can re-roll the Psychic test if it is failed.</description>
        </rule>
      </rules>
      <selectionEntryGroups>
        <selectionEntryGroup id="9886-2585-5b23-2b57" name="Magus" hidden="false" collective="false" defaultSelectionEntryId="090c-cabd-5c5a-ab7d">

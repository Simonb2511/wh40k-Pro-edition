        <characteristic typeId="077c342f-d7b9-45c6-b8af-88e97cafd3a2" name="Type">Heavy 4, Twin-linked</characteristic>
      </characteristics>
    </profile>
    <profile typeId="72c5eafc-75bf-4ed9-b425-78009f1efe82" id="40c3-6e6b-c2a8-c36a" name="Genestealer Familiar" publicationId="f840-ed73-pubd1e7564" hidden="false" typeName="Wargear Item">
      <characteristics>
        <characteristic typeId="21befb24-fc85-4f52-a745-64b2e48f8228" name="Description">A model with a Genestealer Familiar makes two additional S4 AP- attacks with the Rending USR in close combat.  A Genestealer Familiar is represented by a separate miniature that will always remain as close as possible to it&apos;s master.  The model itself is decorative and is always ignored for game purproses - just move it to one side if it gets in the way.  Remove the Genestealer Familiar once it&apos;s master has been slain.</characteristic>
      </characteristics>
    </profile>

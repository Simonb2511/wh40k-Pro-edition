    <profile typeId="d5f97c0b-9fc9-478d-aa34-a7c414d3ea48" id="b448-ed10-d621-819d" name="Scything Talons" hidden="false">
      <characteristics>
        <characteristic typeId="6fa97fa8-ea74-4a27-a0fb-bc4e5f367464" name="Range">-</characteristic>

    <selectionEntry id="67ab-28ad-55c2-a66d" name="Neophyte Cavalcade" hidden="false" collective="false" type="upgrade">
      <rules>
        <rule id="f259-a634-fe53-120d" name="Mechanised Ambush" publicationId="f840-ed73-pubd1e1" page="91" hidden="false">
          <description>This Formation&apos;s units of Neophyte Hybrids must start the game embarked within their transports. Vehicle units from this Formation have the Outflank special rule. Scout Sentinels from this Formation instead gain the Cult Ambush special rule.</description>
        </rule>
        <rule id="030e-9e5a-8fea-766b" name="Devoted Crew" publicationId="f840-ed73-pubd1e1" page="91" hidden="false">
          <description>Roll a dice each time a vehicle from this Formation suffers a Crew Stunned or Crew Shaken result. On a 4 or more that result is ignored (though the vehicle still loses a Hull Point).</description>
        </rule>
      </rules>

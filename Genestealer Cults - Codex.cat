                    <characteristic name="Power Category" typeId="f04c-a782-d794-ddad">Blessing</characteristic>
                    <characteristic name="Range" typeId="fd64-cbc4-94de-24cc">24</characteristic>
                    <characteristic name="Details" typeId="ad96-dfa4-b4ed-656d">A friendly unit within 24&apos;&apos; gain Eternal Warrior, Feel No Pain (5+), Relentless.</characteristic>
                  </characteristics>
                </profile>
              </profiles>
            </selectionEntry>
            <selectionEntry type="upgrade" import="true" name="6 - Haemorrhage" hidden="false" id="0606-a784-6fbd-7fa1">
              <constraints>
                <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="95b9-dfae-721a-9cba" includeChildSelections="false"/>
              </constraints>
              <profiles>
                <profile name="6 - Haemorrhage" typeId="ae70-4738-0161-bec0" typeName="Psychic Power" hidden="false" id="1377-226e-64d5-7f68">
                  <characteristics>
                    <characteristic name="Warp Charge" typeId="5ffd-b800-c317-532a">1</characteristic>
                    <characteristic name="Power Category" typeId="f04c-a782-d794-ddad">Focused Witchfire</characteristic>
                    <characteristic name="Range" typeId="fd64-cbc4-94de-24cc">18</characteristic>
                    <characteristic name="Details" typeId="ad96-dfa4-b4ed-656d">Target model must pass two toughness tests or suffer a wound with no armor or cover saves. If a model is killed, select another model with 2”, which must pass a single toughness test or suffer a wound as well. Repeat until a toughness test is passed.</characteristic>
                  </characteristics>
                </profile>
              </profiles>
            </selectionEntry>
          </selectionEntries>
        </selectionEntry>
        <selectionEntry type="upgrade" import="true" name="Psychic Disicpline - Broodmind" hidden="false" id="5ac8-827a-9682-a9bb">
          <constraints>
            <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="512a-0d7c-758c-d0a8" includeChildSelections="false"/>
          </constraints>
          <selectionEntries>
            <selectionEntry type="upgrade" import="true" name="Primaris Power - Mass Hypnosis" hidden="false" id="f909-8fd3-e613-2c08">
              <constraints>
                <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="d3d9-9d50-6fae-0dc2" includeChildSelections="false"/>
              </constraints>
              <profiles>
                <profile name="Primaris Power - Mass Hypnosis" typeId="ae70-4738-0161-bec0" typeName="Psychic Power" hidden="false" id="de58-bad4-2c86-a79d">
                  <characteristics>
                    <characteristic name="Warp Charge" typeId="5ffd-b800-c317-532a">1</characteristic>
                    <characteristic name="Power Category" typeId="f04c-a782-d794-ddad">Malediction</characteristic>
                    <characteristic name="Range" typeId="fd64-cbc4-94de-24cc">24</characteristic>
                    <characteristic name="Details" typeId="ad96-dfa4-b4ed-656d">Mass Hypnosis is a malediction that targets a single enemy unit within 24”. Whilst this power is in effect, the target’s Weapon Skill, Ballistic Skill, Initiative and Attacks are all reduced by 1, to a minimum of 1.</characteristic>
                  </characteristics>
                </profile>
              </profiles>
            </selectionEntry>
            <selectionEntry type="upgrade" import="true" name="1 - Psychic Stimulus" hidden="false" id="72b6-93ed-a154-53ec">
              <constraints>
                <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="aa88-67ab-ed34-fadd" includeChildSelections="false"/>
              </constraints>
              <profiles>
                <profile name="1 - Psychic Stimulus" typeId="ae70-4738-0161-bec0" typeName="Psychic Power" hidden="false" id="5b98-c39a-35e4-d0fd">
                  <characteristics>
                    <characteristic name="Warp Charge" typeId="5ffd-b800-c317-532a">1</characteristic>
                    <characteristic name="Power Category" typeId="f04c-a782-d794-ddad">Blessing</characteristic>
                    <characteristic name="Range" typeId="fd64-cbc4-94de-24cc">24</characteristic>
                    <characteristic name="Details" typeId="ad96-dfa4-b4ed-656d">Psychic Stimulus is a blessing that targets a single friendly unit within 24” that is not locked in combat. Whilst the power is in effect, the target unit has the Relentless and Fleet special rules. In addition, the target may reroll their run roll.</characteristic>
                  </characteristics>
                </profile>
              </profiles>
            </selectionEntry>
            <selectionEntry type="upgrade" import="true" name="2 - Psionic Blast" hidden="false" id="d2d0-2e29-409c-bf08">
              <constraints>
                <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="7435-0f33-bed5-355f" includeChildSelections="false"/>
              </constraints>
              <profiles>
                <profile name="2 - Psionic Blast" typeId="9c33-b0c8-74bd-e5a7" typeName="Psychic Power (Attack)" hidden="false" id="0816-89c4-6220-d511">
                  <characteristics>
                    <characteristic name="Warp Charge" typeId="c1b6-4261-dee4-923a">1</characteristic>
                    <characteristic name="Power Category" typeId="668e-d504-8244-7422">Witchfire</characteristic>
                    <characteristic name="Range" typeId="5bf6-378a-0cb7-b079">24</characteristic>
                    <characteristic name="Strength" typeId="12da-9b3e-f37b-bc35">5</characteristic>
                    <characteristic name="AP" typeId="10b5-aa5b-ccde-79cc">3</characteristic>
                    <characteristic name="Type" typeId="20e7-cbcb-1781-a732">Assault 1, Blast</characteristic>
                    <characteristic name="Details" typeId="a812-390d-dff6-dabd"/>
                  </characteristics>
                </profile>
              </profiles>
            </selectionEntry>
            <selectionEntry type="upgrade" import="true" name="3 - Might from Beyond" hidden="false" id="e858-69bf-00a9-2599">
              <constraints>
                <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="9e4b-9249-a681-9032" includeChildSelections="false"/>
              </constraints>
              <profiles>
                <profile name="3 - Might from Beyond" typeId="ae70-4738-0161-bec0" typeName="Psychic Power" hidden="false" id="7f89-c5ab-084c-d3cd">
                  <characteristics>
                    <characteristic name="Warp Charge" typeId="5ffd-b800-c317-532a">1</characteristic>
                    <characteristic name="Power Category" typeId="f04c-a782-d794-ddad">Blessing</characteristic>
                    <characteristic name="Range" typeId="fd64-cbc4-94de-24cc">24</characteristic>
                    <characteristic name="Details" typeId="ad96-dfa4-b4ed-656d">Might from Beyond is a blessing that targets a friendly unit within 24”. Whilst this power is in effect, all models in the target unit add 1 to their Strength characteristic and gain the Rage special rule.</characteristic>
                  </characteristics>
                </profile>
              </profiles>
            </selectionEntry>
            <selectionEntry type="upgrade" import="true" name="4 - Mental Onslaught" hidden="false" id="1c08-f3b6-7e0e-f9dd">
              <constraints>
                <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="65f8-97f5-d461-56a1" includeChildSelections="false"/>
              </constraints>
              <profiles>
                <profile name="4 - Mental Onslaught" typeId="ae70-4738-0161-bec0" typeName="Psychic Power" hidden="false" id="0a37-c1e5-19fd-cce3">
                  <characteristics>
                    <characteristic name="Warp Charge" typeId="5ffd-b800-c317-532a">1</characteristic>
                    <characteristic name="Power Category" typeId="f04c-a782-d794-ddad">Focussed Witchfire</characteristic>
                    <characteristic name="Range" typeId="fd64-cbc4-94de-24cc">24</characteristic>
                    <characteristic name="Details" typeId="ad96-dfa4-b4ed-656d">Mental Onslaught is a focussed witchfire power with a range of 24”. Both the Psyker and the target model roll a dice and add their respective Leadership values. If the scores are drawn, the target model suffers a -3 penalty to its Initiative until the end of the following turn. If the Psyker’s score is higher, the target also suffers a number of Wounds equal to the difference between the two scores. No armour or cover saves are allowed against Wounds caused by Mental Onslaught.</characteristic>
                  </characteristics>
                </profile>
              </profiles>
            </selectionEntry>
            <selectionEntry type="upgrade" import="true" name="5 - Mind Control" hidden="false" id="789e-8710-96a7-da0d">
              <constraints>
                <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="80c0-9abf-4b5a-044b" includeChildSelections="false"/>
              </constraints>
              <profiles>
                <profile name="5 - Mind Control" typeId="ae70-4738-0161-bec0" typeName="Psychic Power" hidden="false" id="9e4e-bc18-e3a1-e1eb">
                  <characteristics>
                    <characteristic name="Warp Charge" typeId="5ffd-b800-c317-532a">1</characteristic>
                    <characteristic name="Power Category" typeId="f04c-a782-d794-ddad">Focussed Witchfire</characteristic>
                    <characteristic name="Range" typeId="fd64-cbc4-94de-24cc">24</characteristic>
                    <characteristic name="Details" typeId="ad96-dfa4-b4ed-656d">Mind Control is a focussed witchfire power that targets a single non-vehicle unit within 24” that is not locked in combat. The target immediately makes a shooting attack exactly as if it were one of your own models. The model cannot make an attack that would cause it to hit itself or its own unit in any way. After resolving the shooting attack, the mind-controlled model immediately reverts to the owning player’s control.</characteristic>
                  </characteristics>
                </profile>
              </profiles>
            </selectionEntry>
            <selectionEntry type="upgrade" import="true" name="6 - Telepathic Summons" hidden="false" id="a081-477b-d438-0081">
              <constraints>
                <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="e67a-7dec-5cc7-c023" includeChildSelections="false"/>
              </constraints>
              <profiles>
                <profile name="6 - Telepathic Summons" typeId="ae70-4738-0161-bec0" typeName="Psychic Power" hidden="false" id="1240-df19-d8ba-c5d9">
                  <characteristics>
                    <characteristic name="Warp Charge" typeId="5ffd-b800-c317-532a">2</characteristic>
                    <characteristic name="Power Category" typeId="f04c-a782-d794-ddad">Conjuration</characteristic>
                    <characteristic name="Range" typeId="fd64-cbc4-94de-24cc">Self</characteristic>
                    <characteristic name="Details" typeId="ad96-dfa4-b4ed-656d">Telepathic Summons is a conjuration that creates a single unit; if manifested at Warp Charge 2 it creates one of the following units (your choice):
5 Acolyte Hybrids, 5 Hybrid Metamorphs or 10 Neophyte Hybrids. These units can be equipped with any upgrades listed on their datasheet, but they cannot include any extra models or take a Dedicated Transport. These units always arrive using the Cult Ambush special rule instead of arriving via Deep Strike.</characteristic>
                  </characteristics>
                </profile>
              </profiles>
            </selectionEntry>
          </selectionEntries>
        </selectionEntry>
        <selectionEntry type="upgrade" import="true" name="Psychic Disicpline - Telepathy" hidden="false" id="7a2d-db17-f214-0548">
          <constraints>
            <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="6fc3-a92b-81b7-3391" includeChildSelections="false"/>
          </constraints>
          <selectionEntries>
            <selectionEntry type="upgrade" import="true" name="Primaris Power - Psychic Shriek" hidden="false" id="1b27-6acf-bf93-d4c9">
              <constraints>
                <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="3d88-202f-59db-981e" includeChildSelections="false"/>
              </constraints>
              <profiles>
                <profile name="Primaris Power - Psychic Shriek" typeId="ae70-4738-0161-bec0" typeName="Psychic Power" hidden="false" id="8173-b0b3-181e-626d">
                  <characteristics>
                    <characteristic name="Warp Charge" typeId="5ffd-b800-c317-532a">1</characteristic>
                    <characteristic name="Power Category" typeId="f04c-a782-d794-ddad">Witchfire</characteristic>
                    <characteristic name="Range" typeId="fd64-cbc4-94de-24cc">18</characteristic>
                    <characteristic name="Details" typeId="ad96-dfa4-b4ed-656d">Choose an enemy unit within 18&apos;&apos;. Roll 3D6 and subtract the target’s leadership. Unit suffers wounds equal to the result. No armor and cover saves.</characteristic>
                  </characteristics>
                </profile>
              </profiles>
            </selectionEntry>
            <selectionEntry type="upgrade" import="true" name="1 - Dominate" hidden="false" id="aa20-5b8b-aec6-c9a0">
              <constraints>
                <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="69e8-8122-2994-8675" includeChildSelections="false"/>
              </constraints>
              <profiles>
                <profile name="1 - Dominate" typeId="ae70-4738-0161-bec0" typeName="Psychic Power" hidden="false" id="8e92-c2c9-492f-ebc6">
                  <characteristics>
                    <characteristic name="Warp Charge" typeId="5ffd-b800-c317-532a">1</characteristic>
                    <characteristic name="Power Category" typeId="f04c-a782-d794-ddad">Malediction</characteristic>
                    <characteristic name="Range" typeId="fd64-cbc4-94de-24cc">24</characteristic>
                    <characteristic name="Details" typeId="ad96-dfa4-b4ed-656d">Target unit must pass a leadership test each time it attempts to move, advance, shoot, charge, or use a psychic power.</characteristic>
                  </characteristics>
                </profile>
              </profiles>
            </selectionEntry>
            <selectionEntry type="upgrade" import="true" name="2 - Mental Fortitude" hidden="false" id="cfe9-0a77-7fe3-1ecd">
              <constraints>
                <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="cc8e-75cf-c679-b76e" includeChildSelections="false"/>
              </constraints>
              <profiles>
                <profile name="2 - Mental Fortitude" typeId="ae70-4738-0161-bec0" typeName="Psychic Power" hidden="false" id="a0ec-71ed-82d4-12d4">
                  <characteristics>
                    <characteristic name="Warp Charge" typeId="5ffd-b800-c317-532a">1</characteristic>
                    <characteristic name="Power Category" typeId="f04c-a782-d794-ddad">Mental Fortitude</characteristic>
                    <characteristic name="Range" typeId="fd64-cbc4-94de-24cc">24</characteristic>
                    <characteristic name="Details" typeId="ad96-dfa4-b4ed-656d">If the target is falling back, it immediately regroups. The target gains Fearless.</characteristic>
                  </characteristics>
                </profile>
              </profiles>
            </selectionEntry>
            <selectionEntry type="upgrade" import="true" name="3 - Terrify" hidden="false" id="27e7-ea9d-d1ef-0cb4">
              <constraints>
                <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="234a-d94a-24f8-a528" includeChildSelections="false"/>
              </constraints>
              <profiles>
                <profile name="3 - Terrify" typeId="ae70-4738-0161-bec0" typeName="Psychic Power" hidden="false" id="ea55-03a1-cdf3-6094">
                  <characteristics>
                    <characteristic name="Warp Charge" typeId="5ffd-b800-c317-532a">1</characteristic>
                    <characteristic name="Power Category" typeId="f04c-a782-d794-ddad">Malediction</characteristic>
                    <characteristic name="Range" typeId="fd64-cbc4-94de-24cc">24</characteristic>
                    <characteristic name="Details" typeId="ad96-dfa4-b4ed-656d">Target enemy unit has -1 to their leadership and treats all opposing units as if they had Fear. Must take a casualty test at the end of the turn.</characteristic>
                  </characteristics>
                </profile>
              </profiles>
            </selectionEntry>
            <selectionEntry type="upgrade" import="true" name="4 - Hallucination" hidden="false" id="fe32-fa2b-b205-c209">
              <constraints>
                <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="0ce0-449e-1991-90d2" includeChildSelections="false"/>
              </constraints>
              <profiles>
                <profile name="4 - Hallucination" typeId="ae70-4738-0161-bec0" typeName="Psychic Power" hidden="false" id="0cf3-e1fa-7221-8c3d">
                  <characteristics>
                    <characteristic name="Warp Charge" typeId="5ffd-b800-c317-532a">1</characteristic>
                    <characteristic name="Power Category" typeId="f04c-a782-d794-ddad">Malediction</characteristic>
                    <characteristic name="Range" typeId="fd64-cbc4-94de-24cc">24</characteristic>
                    <characteristic name="Details" typeId="ad96-dfa4-b4ed-656d">Roll a D6 and the unit suffers the below result:
1-2: Unit must take a pinning test
3-4: Unit suffers -1 to WS, BS, Initiative, Attacks
5-6: Randomly select a model in the unit. It takes a hit for every other model in the unit, with strength equal to the majority strength in the unit.</characteristic>
                  </characteristics>
                </profile>
              </profiles>
            </selectionEntry>
            <selectionEntry type="upgrade" import="true" name="5 - Invisiblity" hidden="false" id="3d20-f59a-a844-cda0">
              <constraints>
                <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="db78-8b46-1a97-3da1" includeChildSelections="false"/>
              </constraints>
              <profiles>
                <profile name="5 - Invisiblity" typeId="ae70-4738-0161-bec0" typeName="Psychic Power" hidden="false" id="e7f9-3e62-e31b-8d1e">
                  <characteristics>
                    <characteristic name="Warp Charge" typeId="5ffd-b800-c317-532a">1</characteristic>
                    <characteristic name="Power Category" typeId="f04c-a782-d794-ddad">Blessing</characteristic>
                    <characteristic name="Range" typeId="fd64-cbc4-94de-24cc">24</characteristic>
                    <characteristic name="Details" typeId="ad96-dfa4-b4ed-656d">Select one friendly unit within 24&apos;&apos;. Opposing units suffer a -1 to hit when making ranged and melee attacks against the target unit.</characteristic>
                  </characteristics>
                </profile>
              </profiles>
            </selectionEntry>
            <selectionEntry type="upgrade" import="true" name="6 - Shrouding" hidden="false" id="9841-feb3-c459-08a6">
              <constraints>
                <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="bacc-0672-a31e-c8c7" includeChildSelections="false"/>
              </constraints>
              <profiles>
                <profile name="6 - Shrouding" typeId="ae70-4738-0161-bec0" typeName="Psychic Power" hidden="false" id="fdb8-5a30-a773-7d7f">
                  <characteristics>
                    <characteristic name="Warp Charge" typeId="5ffd-b800-c317-532a">1</characteristic>
                    <characteristic name="Power Category" typeId="f04c-a782-d794-ddad">Blessing</characteristic>
                    <characteristic name="Range" typeId="fd64-cbc4-94de-24cc">Self</characteristic>
                    <characteristic name="Details" typeId="ad96-dfa4-b4ed-656d">All friendly models within 6” of the psyker have the shrouded special rule.</characteristic>
                  </characteristics>
                </profile>
              </profiles>
            </selectionEntry>
          </selectionEntries>
        </selectionEntry>
      </selectionEntries>

          <selectionEntries>
            <selectionEntry id="6c93-c221-79d5-90c2" name="Genestealer Cults" hidden="false" collective="false" type="upgrade">
              <profiles>
                <profile typeId="72c5eafc-75bf-4ed9-b425-78009f1efe82" typeName="Wargear Item" id="daf9-1142-11a4-ffba" name="Warlord Trait: Shadow Stalker" publicationId="f840-ed73-pubd1e1" page="96" hidden="false">
                  <characteristics>
                    <characteristic typeId="21befb24-fc85-4f52-a745-64b2e48f8228" name="Description">Your Warlord has the Stealth special rule.</characteristic>
                  </characteristics>
                </profile>
                <profile typeId="72c5eafc-75bf-4ed9-b425-78009f1efe82" typeName="Wargear Item" id="934a-05a7-98bd-d411" name="Warlord Trait: Ambush Leader" publicationId="f840-ed73-pubd1e1" page="96" hidden="false">
                  <characteristics>
                    <characteristic name="Description" typeId="21befb24-fc85-4f52-a745-64b2e48f8228">When using the Cult Ambush special rule your Warlord or any unit he has joined may modify the result with +1</characteristic>
                  </characteristics>
                </profile>
                <profile typeId="72c5eafc-75bf-4ed9-b425-78009f1efe82" typeName="Wargear Item" id="4423-6c28-9b6a-6e39" name="Warlord Trait: Alien Master" publicationId="f840-ed73-pubd1e1" page="96" hidden="false">
                  <characteristics>
                    <characteristic typeId="21befb24-fc85-4f52-a745-64b2e48f8228" name="Description">All models in your Warlord&apos;s Detachment can use his Leadership in place of their own.</characteristic>
                  </characteristics>
                </profile>
                <profile typeId="72c5eafc-75bf-4ed9-b425-78009f1efe82" typeName="Wargear Item" id="c46d-5b11-6de6-8ebd" name="Warlord Trait: Born Survivor" publicationId="f840-ed73-pubd1e1" page="96" hidden="false">
                  <characteristics>
                    <characteristic typeId="21befb24-fc85-4f52-a745-64b2e48f8228" name="Description">Your Warlord has the It Will Not Die special rule.</characteristic>
                  </characteristics>
                </profile>
                <profile typeId="72c5eafc-75bf-4ed9-b425-78009f1efe82" typeName="Wargear Item" id="5cf3-551a-04a4-c6ff" name="Warlord Trait: Wall Creeper" publicationId="f840-ed73-pubd1e1" page="96" hidden="false">
                  <characteristics>
                    <characteristic typeId="21befb24-fc85-4f52-a745-64b2e48f8228" name="Description">Your Warlord has the Move Through Cover special rule. In addition, your Warlord and his unit never suffer the penalty to their Initiative for charging through difficult terrain.</characteristic>
                  </characteristics>
                </profile>
                <profile typeId="72c5eafc-75bf-4ed9-b425-78009f1efe82" typeName="Wargear Item" id="a36b-276f-3617-00d7" name="Warlord Trait: Focus of Adoration" publicationId="f840-ed73-pubd1e1" page="96" hidden="false">
                  <characteristics>
                    <characteristic typeId="21befb24-fc85-4f52-a745-64b2e48f8228" name="Description">Friendly units with the Genestealer Cults Faction have the Counter-Attack special rule while they are within 12&quot; of your Warlord.</characteristic>
                  </characteristics>
                </profile>
              </profiles>

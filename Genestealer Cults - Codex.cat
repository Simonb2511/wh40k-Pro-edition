    <selectionEntry id="091e-f0c1-1a4a-6b3b" name="Brood Cycle" hidden="false" collective="false" type="upgrade">
      <rules>
        <rule id="d8f9-65f1-34ab-b842" name="Familial Pride" publicationId="f840-ed73-pubd1e1" page="89" hidden="false">
          <description>Any non-vehicle unit in this Formation that is within 6&quot; of at least one other unit from the same Formation adds 1 to both its Leadership and its Weapon Skill.</description>
        </rule>
        <rule id="da65-b9f1-96e4-de04" name="Hold the Banner High" hidden="false">
          <description>All units from this Formation have the Furious Charge special rule while they are within 24&quot; of their Acolyte Iconward. In addition, the range of the Acolyte Iconward&apos;s Nexus of Devotion special rule will effect units from this Formation that are within 24&quot; of him, instead of just 12&quot;.</description>
        </rule>
      </rules>
      <selectionEntryGroups>

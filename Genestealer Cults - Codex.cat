        <categoryLink id="e34d-8198-502a-4daa-ff36a6f3-19bf-4f48-8956-adacfd28fe74" targetId="ff36a6f3-19bf-4f48-8956-adacfd28fe74" name="No Force Org Slot" hidden="false"/>
      </categoryLinks>
      <rules>
        <rule id="58e0-93d6-48a2-5357" name="Cult Father" publicationId="f840-ed73-pubd1e1" page="66" hidden="false">
          <description>If you choose a Patriarch from this Detachment as your Warlord, you can re-roll the result when rolling on the Warlord Traits table in Codex: Genestealer Cults.</description>
        </rule>
        <rule id="a585-cf83-fe47-cbf5" name="An Uprising Generations in the Making" publicationId="f840-ed73-pubd1e1" page="66" hidden="false">
          <description>All non-vehicle units in this Detachment have the Infiltrate special rule (units that already hve the Infiltrate special rule instead have the Shrouded special rule during the first game turn). In addition, you can add 1 to all your Reserve Rolls, whilst your opponent must subtract 1 from all their Reserve Rolls.</description>
        </rule>
        <rule id="7538-e1d1-9a7a-9722" name="Numbers Beyond Counting" publicationId="f840-ed73-pubd1e1" page="66" hidden="false">
          <description>Each time a unit from this Detachment arrives from Ongoing Reserves, it is reinforced - you can return D6 models to the unit that were slain previously during the battle.</description>
        </rule>
      </rules>
      <infoLinks>
        <infoLink id="9856-8427-197e-6438" name="Infiltrate" hidden="false" targetId="0b11-a0ff-f0ba-5341" type="rule"/>
        <infoLink id="0d2d-84ca-62bc-ca97" name="Shrouded" hidden="false" targetId="7182-6dce-dc98-9f7c" type="rule"/>
      </infoLinks>
    </forceEntry>
  </forceEntries>

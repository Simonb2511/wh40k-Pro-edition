            <characteristic typeId="a6383362-5aa8-4ff0-b1d0-00e059fc9d45" name="Strength">User</characteristic>
            <characteristic typeId="6abee736-f8d3-498e-97ac-a5c68445609f" name="AP">-</characteristic>
            <characteristic typeId="077c342f-d7b9-45c6-b8af-88e97cafd3a2" name="Type">Melee, Instant Death, Poisoned (2+)</characteristic>
          </characteristics>
        </profile>
      </profiles>
      <rules>
        <rule id="ef66-201e-48fb-0d4a" name="Dagger of the Swift Sacrifice" publicationId="f840-ed73-pubd1e1" page="101" hidden="false">
          <description>When making its close combat attacks, a model with the Dagger of the Swift Sacrifice can instead make a single attack, rolling To Hit as normal, using the profile of the weapon.</description>
        </rule>
      </rules>

    <profile name="Survey Auger" typeId="72c5eafc-75bf-4ed9-b425-78009f1efe82" typeName="Wargear Item" hidden="false" id="7315-f414-c1df-78df">
      <characteristics>
        <characteristic name="Description" typeId="21befb24-fc85-4f52-a745-64b2e48f8228">Enemy units hit by this weapon suffers a -1 penalty to their Cover Saves for the rest of their turn.</characteristic>
      </characteristics>
    </profile>
    <profile name="Flare Launchers" typeId="72c5eafc-75bf-4ed9-b425-78009f1efe82" typeName="Wargear Item" hidden="false" id="6a2e-7c30-84fc-d9e9">
      <characteristics>
        <characteristic name="Description" typeId="21befb24-fc85-4f52-a745-64b2e48f8228">Once per game, when this model is targeted by a shooting attack, it may activate its flare launchers to gain a 4+ Cover Save for the rest of the turn.</characteristic>
      </characteristics>
    </profile>

    <profile typeId="72c5eafc-75bf-4ed9-b425-78009f1efe82" id="afa7-d6cf-cbe9-68db" name="Sacred Cult Banner" hidden="false">
      <characteristics>
        <characteristic typeId="21befb24-fc85-4f52-a745-64b2e48f8228" name="Description">Friendly units with the Genestealer Cults Faction within 12&quot; of a model equiped with a sacred cult banner have the Furious Charge special rule.</characteristic>
      </characteristics>
    </profile>
    <profile typeId="3dadd2ff-33f1-41dd-85c7-bee5a7dfa413" id="c25e-7f8d-cc67-9047" name="Scout Sentinel" publicationId="f840-ed73-pubd1e1" page="82" hidden="false" typeName="Walker">
      <characteristics>
        <characteristic typeId="5ee4ff0b-b244-4670-9d05-91d10f80c32e" name="WS">3</characteristic>

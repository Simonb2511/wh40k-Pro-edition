                    <characteristic name="Warp Charge" typeId="5ffd-b800-c317-532a">1</characteristic>
                    <characteristic name="Power Category" typeId="f04c-a782-d794-ddad">Blessing</characteristic>
                    <characteristic name="Range" typeId="fd64-cbc4-94de-24cc">24</characteristic>
                    <characteristic name="Details" typeId="ad96-dfa4-b4ed-656d">A friendly unit within 24&apos;&apos; gain Eternal Warrior, Feel No Pain (5+), Relentless.</characteristic>
                  </characteristics>
                </profile>
              </profiles>
            </selectionEntry>
            <selectionEntry type="upgrade" import="true" name="6 - Haemorrhage" hidden="false" id="361d-a521-6ce8-ae9a">
              <constraints>
                <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="9646-a590-75b0-dbd6" includeChildSelections="false"/>
              </constraints>
              <profiles>
                <profile name="6 - Haemorrhage" typeId="ae70-4738-0161-bec0" typeName="Psychic Power" hidden="false" id="c661-25fa-a424-cc3c">
                  <characteristics>
                    <characteristic name="Warp Charge" typeId="5ffd-b800-c317-532a">1</characteristic>
                    <characteristic name="Power Category" typeId="f04c-a782-d794-ddad">Focused Witchfire</characteristic>
                    <characteristic name="Range" typeId="fd64-cbc4-94de-24cc">18</characteristic>
                    <characteristic name="Details" typeId="ad96-dfa4-b4ed-656d">Target model must pass two toughness tests or suffer a wound with no armor or cover saves. If a model is killed, select another model with 2”, which must pass a single toughness test or suffer a wound as well. Repeat until a toughness test is passed.</characteristic>
                  </characteristics>
                </profile>
              </profiles>
            </selectionEntry>
          </selectionEntries>
        </selectionEntry>
        <selectionEntry type="upgrade" import="true" name="Psychic Disicpline - Broodmind" hidden="false" id="fae8-eff9-ab2f-f745">
          <constraints>
            <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="dfda-4c19-8e52-aac0" includeChildSelections="false"/>
          </constraints>
          <selectionEntries>
            <selectionEntry type="upgrade" import="true" name="Primaris Power - Mass Hypnosis" hidden="false" id="ecd5-7987-16bc-7b65">
              <constraints>
                <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="f7d1-b7ca-d9f7-10be" includeChildSelections="false"/>
              </constraints>
              <profiles>
                <profile name="Primaris Power - Mass Hypnosis" typeId="ae70-4738-0161-bec0" typeName="Psychic Power" hidden="false" id="ab34-bf37-8212-1bdd">
                  <characteristics>
                    <characteristic name="Warp Charge" typeId="5ffd-b800-c317-532a">1</characteristic>
                    <characteristic name="Power Category" typeId="f04c-a782-d794-ddad">Malediction</characteristic>
                    <characteristic name="Range" typeId="fd64-cbc4-94de-24cc">24</characteristic>
                    <characteristic name="Details" typeId="ad96-dfa4-b4ed-656d">Mass Hypnosis is a malediction that targets a single enemy unit within 24”. Whilst this power is in effect, the target’s Weapon Skill, Ballistic Skill, Initiative and Attacks are all reduced by 1, to a minimum of 1.</characteristic>
                  </characteristics>
                </profile>
              </profiles>
            </selectionEntry>
            <selectionEntry type="upgrade" import="true" name="1 - Psychic Stimulus" hidden="false" id="ae82-005e-74ab-d297">
              <constraints>
                <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="cd03-ce74-f4d3-9c10" includeChildSelections="false"/>
              </constraints>
              <profiles>
                <profile name="1 - Psychic Stimulus" typeId="ae70-4738-0161-bec0" typeName="Psychic Power" hidden="false" id="2cf4-6074-9d70-a2d4">
                  <characteristics>
                    <characteristic name="Warp Charge" typeId="5ffd-b800-c317-532a">1</characteristic>
                    <characteristic name="Power Category" typeId="f04c-a782-d794-ddad">Blessing</characteristic>
                    <characteristic name="Range" typeId="fd64-cbc4-94de-24cc">24</characteristic>
                    <characteristic name="Details" typeId="ad96-dfa4-b4ed-656d">Psychic Stimulus is a blessing that targets a single friendly unit within 24” that is not locked in combat. Whilst the power is in effect, the target unit has the Relentless and Fleet special rules. In addition, the target may reroll their run roll.</characteristic>
                  </characteristics>
                </profile>
              </profiles>
            </selectionEntry>
            <selectionEntry type="upgrade" import="true" name="2 - Psionic Blast" hidden="false" id="d2e9-25c6-d515-591d">
              <constraints>
                <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="f131-cfe2-20f9-647a" includeChildSelections="false"/>
              </constraints>
              <profiles>
                <profile name="2 - Psionic Blast" typeId="9c33-b0c8-74bd-e5a7" typeName="Psychic Power (Attack)" hidden="false" id="1cbb-80a1-3c42-82bf">
                  <characteristics>
                    <characteristic name="Warp Charge" typeId="c1b6-4261-dee4-923a">1</characteristic>
                    <characteristic name="Power Category" typeId="668e-d504-8244-7422">Witchfire</characteristic>
                    <characteristic name="Range" typeId="5bf6-378a-0cb7-b079">24</characteristic>
                    <characteristic name="Strength" typeId="12da-9b3e-f37b-bc35">5</characteristic>
                    <characteristic name="AP" typeId="10b5-aa5b-ccde-79cc">3</characteristic>
                    <characteristic name="Type" typeId="20e7-cbcb-1781-a732">Assault 1, Blast</characteristic>
                    <characteristic name="Details" typeId="a812-390d-dff6-dabd"/>
                  </characteristics>
                </profile>
              </profiles>
            </selectionEntry>
            <selectionEntry type="upgrade" import="true" name="3 - Might from Beyond" hidden="false" id="8470-550e-d95c-931f">
              <constraints>
                <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="0a77-a196-cc8c-fbe1" includeChildSelections="false"/>
              </constraints>
              <profiles>
                <profile name="3 - Might from Beyond" typeId="ae70-4738-0161-bec0" typeName="Psychic Power" hidden="false" id="ceff-e68e-c733-b461">
                  <characteristics>
                    <characteristic name="Warp Charge" typeId="5ffd-b800-c317-532a">1</characteristic>
                    <characteristic name="Power Category" typeId="f04c-a782-d794-ddad">Blessing</characteristic>
                    <characteristic name="Range" typeId="fd64-cbc4-94de-24cc">24</characteristic>
                    <characteristic name="Details" typeId="ad96-dfa4-b4ed-656d">Might from Beyond is a blessing that targets a friendly unit within 24”. Whilst this power is in effect, all models in the target unit add 1 to their Strength characteristic and gain the Rage special rule.</characteristic>
                  </characteristics>
                </profile>
              </profiles>
            </selectionEntry>
            <selectionEntry type="upgrade" import="true" name="4 - Mental Onslaught" hidden="false" id="bd76-6fda-cf56-045a">
              <constraints>
                <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="a8f4-2fd7-adda-96e8" includeChildSelections="false"/>
              </constraints>
              <profiles>
                <profile name="4 - Mental Onslaught" typeId="ae70-4738-0161-bec0" typeName="Psychic Power" hidden="false" id="d3e0-7d25-7f8b-4dfd">
                  <characteristics>
                    <characteristic name="Warp Charge" typeId="5ffd-b800-c317-532a">1</characteristic>
                    <characteristic name="Power Category" typeId="f04c-a782-d794-ddad">Focussed Witchfire</characteristic>
                    <characteristic name="Range" typeId="fd64-cbc4-94de-24cc">24</characteristic>
                    <characteristic name="Details" typeId="ad96-dfa4-b4ed-656d">Mental Onslaught is a focussed witchfire power with a range of 24”. Both the Psyker and the target model roll a dice and add their respective Leadership values. If the scores are drawn, the target model suffers a -3 penalty to its Initiative until the end of the following turn. If the Psyker’s score is higher, the target also suffers a number of Wounds equal to the difference between the two scores. No armour or cover saves are allowed against Wounds caused by Mental Onslaught.</characteristic>
                  </characteristics>
                </profile>
              </profiles>
            </selectionEntry>
            <selectionEntry type="upgrade" import="true" name="5 - Mind Control" hidden="false" id="3add-ce2b-aa1c-b031">
              <constraints>
                <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="1c7e-6779-0f5b-0fd1" includeChildSelections="false"/>
              </constraints>
              <profiles>
                <profile name="5 - Mind Control" typeId="ae70-4738-0161-bec0" typeName="Psychic Power" hidden="false" id="2fae-4000-132b-7daa">
                  <characteristics>
                    <characteristic name="Warp Charge" typeId="5ffd-b800-c317-532a">1</characteristic>
                    <characteristic name="Power Category" typeId="f04c-a782-d794-ddad">Focussed Witchfire</characteristic>
                    <characteristic name="Range" typeId="fd64-cbc4-94de-24cc">24</characteristic>
                    <characteristic name="Details" typeId="ad96-dfa4-b4ed-656d">Mind Control is a focussed witchfire power that targets a single non-vehicle unit within 24” that is not locked in combat. The target immediately makes a shooting attack exactly as if it were one of your own models. The model cannot make an attack that would cause it to hit itself or its own unit in any way. After resolving the shooting attack, the mind-controlled model immediately reverts to the owning player’s control.</characteristic>
                  </characteristics>
                </profile>
              </profiles>
            </selectionEntry>
            <selectionEntry type="upgrade" import="true" name="6 - Telepathic Summons" hidden="false" id="fb2a-1135-cd76-af01">
              <constraints>
                <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="73b5-531c-7011-26ae" includeChildSelections="false"/>
              </constraints>
              <profiles>
                <profile name="6 - Telepathic Summons" typeId="ae70-4738-0161-bec0" typeName="Psychic Power" hidden="false" id="f384-d82d-2e36-e2c4">
                  <characteristics>
                    <characteristic name="Warp Charge" typeId="5ffd-b800-c317-532a">2</characteristic>
                    <characteristic name="Power Category" typeId="f04c-a782-d794-ddad">Conjuration</characteristic>
                    <characteristic name="Range" typeId="fd64-cbc4-94de-24cc">Self</characteristic>
                    <characteristic name="Details" typeId="ad96-dfa4-b4ed-656d">Telepathic Summons is a conjuration that creates a single unit; if manifested at Warp Charge 2 it creates one of the following units (your choice):
5 Acolyte Hybrids, 5 Hybrid Metamorphs or 10 Neophyte Hybrids. These units can be equipped with any upgrades listed on their datasheet, but they cannot include any extra models or take a Dedicated Transport. These units always arrive using the Cult Ambush special rule instead of arriving via Deep Strike.</characteristic>
                  </characteristics>
                </profile>
              </profiles>
            </selectionEntry>
          </selectionEntries>
        </selectionEntry>
        <selectionEntry type="upgrade" import="true" name="Psychic Disicpline - Telepathy" hidden="false" id="f686-39dd-baff-1c50">
          <constraints>
            <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="7490-ba10-2371-2531" includeChildSelections="false"/>
          </constraints>
          <selectionEntries>
            <selectionEntry type="upgrade" import="true" name="Primaris Power - Psychic Shriek" hidden="false" id="0f25-e265-98a8-8745">
              <constraints>
                <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="68e1-c3fb-507c-8e5f" includeChildSelections="false"/>
              </constraints>
              <profiles>
                <profile name="Primaris Power - Psychic Shriek" typeId="ae70-4738-0161-bec0" typeName="Psychic Power" hidden="false" id="0520-5e87-4fe1-dd7c">
                  <characteristics>
                    <characteristic name="Warp Charge" typeId="5ffd-b800-c317-532a">1</characteristic>
                    <characteristic name="Power Category" typeId="f04c-a782-d794-ddad">Witchfire</characteristic>
                    <characteristic name="Range" typeId="fd64-cbc4-94de-24cc">18</characteristic>
                    <characteristic name="Details" typeId="ad96-dfa4-b4ed-656d">Choose an enemy unit within 18&apos;&apos;. Roll 3D6 and subtract the target’s leadership. Unit suffers wounds equal to the result. No armor and cover saves.</characteristic>
                  </characteristics>
                </profile>
              </profiles>
            </selectionEntry>
            <selectionEntry type="upgrade" import="true" name="1 - Dominate" hidden="false" id="585e-e68f-1517-c7e3">
              <constraints>
                <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="fc50-3b91-7a17-074c" includeChildSelections="false"/>
              </constraints>
              <profiles>
                <profile name="1 - Dominate" typeId="ae70-4738-0161-bec0" typeName="Psychic Power" hidden="false" id="6b75-28dc-df89-6972">
                  <characteristics>
                    <characteristic name="Warp Charge" typeId="5ffd-b800-c317-532a">1</characteristic>
                    <characteristic name="Power Category" typeId="f04c-a782-d794-ddad">Malediction</characteristic>
                    <characteristic name="Range" typeId="fd64-cbc4-94de-24cc">24</characteristic>
                    <characteristic name="Details" typeId="ad96-dfa4-b4ed-656d">Target unit must pass a leadership test each time it attempts to move, advance, shoot, charge, or use a psychic power.</characteristic>
                  </characteristics>
                </profile>
              </profiles>
            </selectionEntry>
            <selectionEntry type="upgrade" import="true" name="2 - Mental Fortitude" hidden="false" id="eccd-d036-5034-6b10">
              <constraints>
                <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="c9d6-2620-b926-48ba" includeChildSelections="false"/>
              </constraints>
              <profiles>
                <profile name="2 - Mental Fortitude" typeId="ae70-4738-0161-bec0" typeName="Psychic Power" hidden="false" id="c7ef-3c85-b8d1-b806">
                  <characteristics>
                    <characteristic name="Warp Charge" typeId="5ffd-b800-c317-532a">1</characteristic>
                    <characteristic name="Power Category" typeId="f04c-a782-d794-ddad">Mental Fortitude</characteristic>
                    <characteristic name="Range" typeId="fd64-cbc4-94de-24cc">24</characteristic>
                    <characteristic name="Details" typeId="ad96-dfa4-b4ed-656d">If the target is falling back, it immediately regroups. The target gains Fearless.</characteristic>
                  </characteristics>
                </profile>
              </profiles>
            </selectionEntry>
            <selectionEntry type="upgrade" import="true" name="3 - Terrify" hidden="false" id="406d-d9f3-ac8b-77aa">
              <constraints>
                <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="0799-3841-d2b6-9d34" includeChildSelections="false"/>
              </constraints>
              <profiles>
                <profile name="3 - Terrify" typeId="ae70-4738-0161-bec0" typeName="Psychic Power" hidden="false" id="9778-6b73-f70b-acba">
                  <characteristics>
                    <characteristic name="Warp Charge" typeId="5ffd-b800-c317-532a">1</characteristic>
                    <characteristic name="Power Category" typeId="f04c-a782-d794-ddad">Malediction</characteristic>
                    <characteristic name="Range" typeId="fd64-cbc4-94de-24cc">24</characteristic>
                    <characteristic name="Details" typeId="ad96-dfa4-b4ed-656d">Target enemy unit has -1 to their leadership and treats all opposing units as if they had Fear. Must take a casualty test at the end of the turn.</characteristic>
                  </characteristics>
                </profile>
              </profiles>
            </selectionEntry>
            <selectionEntry type="upgrade" import="true" name="4 - Hallucination" hidden="false" id="d05f-de5c-696f-3d18">
              <constraints>
                <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="34e3-61fd-4737-df7d" includeChildSelections="false"/>
              </constraints>
              <profiles>
                <profile name="4 - Hallucination" typeId="ae70-4738-0161-bec0" typeName="Psychic Power" hidden="false" id="bd3a-0d87-5075-a7ac">
                  <characteristics>
                    <characteristic name="Warp Charge" typeId="5ffd-b800-c317-532a">1</characteristic>
                    <characteristic name="Power Category" typeId="f04c-a782-d794-ddad">Malediction</characteristic>
                    <characteristic name="Range" typeId="fd64-cbc4-94de-24cc">24</characteristic>
                    <characteristic name="Details" typeId="ad96-dfa4-b4ed-656d">Roll a D6 and the unit suffers the below result:
1-2: Unit must take a pinning test
3-4: Unit suffers -1 to WS, BS, Initiative, Attacks
5-6: Randomly select a model in the unit. It takes a hit for every other model in the unit, with strength equal to the majority strength in the unit.</characteristic>
                  </characteristics>
                </profile>
              </profiles>
            </selectionEntry>
            <selectionEntry type="upgrade" import="true" name="5 - Invisiblity" hidden="false" id="9a48-2443-c45b-af0f">
              <constraints>
                <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="ab3c-997c-3e39-f1ad" includeChildSelections="false"/>
              </constraints>
              <profiles>
                <profile name="5 - Invisiblity" typeId="ae70-4738-0161-bec0" typeName="Psychic Power" hidden="false" id="0c7f-31f6-6c85-6c3d">
                  <characteristics>
                    <characteristic name="Warp Charge" typeId="5ffd-b800-c317-532a">1</characteristic>
                    <characteristic name="Power Category" typeId="f04c-a782-d794-ddad">Blessing</characteristic>
                    <characteristic name="Range" typeId="fd64-cbc4-94de-24cc">24</characteristic>
                    <characteristic name="Details" typeId="ad96-dfa4-b4ed-656d">Select one friendly unit within 24&apos;&apos;. Opposing units suffer a -1 to hit when making ranged and melee attacks against the target unit.</characteristic>
                  </characteristics>
                </profile>
              </profiles>
            </selectionEntry>
            <selectionEntry type="upgrade" import="true" name="6 - Shrouding" hidden="false" id="9383-9c45-0903-f37d">
              <constraints>
                <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="0bb2-a7b0-b4c4-2b88" includeChildSelections="false"/>
              </constraints>
              <profiles>
                <profile name="6 - Shrouding" typeId="ae70-4738-0161-bec0" typeName="Psychic Power" hidden="false" id="3fc8-6810-791c-da09">
                  <characteristics>
                    <characteristic name="Warp Charge" typeId="5ffd-b800-c317-532a">1</characteristic>
                    <characteristic name="Power Category" typeId="f04c-a782-d794-ddad">Blessing</characteristic>
                    <characteristic name="Range" typeId="fd64-cbc4-94de-24cc">Self</characteristic>
                    <characteristic name="Details" typeId="ad96-dfa4-b4ed-656d">All friendly models within 6” of the psyker have the shrouded special rule.</characteristic>
                  </characteristics>
                </profile>
              </profiles>
            </selectionEntry>
          </selectionEntries>
        </selectionEntry>
      </selectionEntries>

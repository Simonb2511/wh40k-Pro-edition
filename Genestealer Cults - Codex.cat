        <rule name="Cameo-Cloak" id="9dab-aaa8-3541-88ce" hidden="false">
          <description>The Sanctus Sniper cannot be targeted by shooting or psychic attacks unless the attacker is within 12&quot;. This does not apply to barrage weapons or those that do not require line of sight.</description>
        </rule>
        <rule name="On the move" id="265b-9d5a-695c-0760" hidden="false">

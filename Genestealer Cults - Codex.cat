          <constraints>
            <constraint field="selections" scope="parent" value="1" percentValue="false" shared="false" includeChildSelections="false" includeChildForces="false" id="65ca-71d9-e454-27b8" type="max"/>
          </constraints>
          <selectionEntries>
            <selectionEntry id="4f24-8155-92f3-6a40" name="Discipline: Broodmind" hidden="false" collective="false" type="upgrade">
              <profiles>
                <profile typeId="ae70-4738-0161-bec0" typeName="Psychic Power" id="0f5c-22fe-61fe-7c3d" name="(Primaris) Mass Hypnosis" hidden="false">
                  <characteristics>
                    <characteristic typeId="5ffd-b800-c317-532a" name="Warp Charge">1</characteristic>
                    <characteristic typeId="f04c-a782-d794-ddad" name="Power Category">Malediction</characteristic>
                    <characteristic typeId="fd64-cbc4-94de-24cc" name="Range">24&quot;</characteristic>
                    <characteristic typeId="ad96-dfa4-b4ed-656d" name="Details">A single enemy unit has its Weapon Skill, Balistic Skill, Initiative and Attacks reduced by 1, to a minimum of 1.</characteristic>
                  </characteristics>
                </profile>
                <profile typeId="ae70-4738-0161-bec0" typeName="Psychic Power" id="a645-0cf4-3af2-ff03" name="Psychic Stimulus" hidden="false">
                  <characteristics>
                    <characteristic typeId="5ffd-b800-c317-532a" name="Warp Charge">1</characteristic>
                    <characteristic typeId="f04c-a782-d794-ddad" name="Power Category">Blessing</characteristic>
                    <characteristic typeId="fd64-cbc4-94de-24cc" name="Range">24&quot;</characteristic>
                    <characteristic typeId="ad96-dfa4-b4ed-656d" name="Details">A single friendly unit gains the Relentless and Fleet special rules. In addition, the target can charge even if it Ran its preceding Shooting phase.</characteristic>
                  </characteristics>
                </profile>
                <profile typeId="9c33-b0c8-74bd-e5a7" typeName="Psychic Power (Attack)" id="decd-b780-d35e-efd1" name="Psionic Blast" hidden="false">
                  <characteristics>
                    <characteristic typeId="c1b6-4261-dee4-923a" name="Warp Charge">1</characteristic>
                    <characteristic typeId="668e-d504-8244-7422" name="Power Category">Witchfire</characteristic>
                    <characteristic typeId="5bf6-378a-0cb7-b079" name="Range">24&quot;</characteristic>
                    <characteristic typeId="12da-9b3e-f37b-bc35" name="Strength">5</characteristic>
                    <characteristic typeId="10b5-aa5b-ccde-79cc" name="AP">3</characteristic>
                    <characteristic typeId="20e7-cbcb-1781-a732" name="Type">Assault 1, Blast</characteristic>
                    <characteristic typeId="a812-390d-dff6-dabd" name="Details"/>
                  </characteristics>
                </profile>
                <profile typeId="ae70-4738-0161-bec0" typeName="Psychic Power" id="ba36-f134-cff2-d711" name="Might From Beyond" hidden="false">
                  <characteristics>
                    <characteristic typeId="5ffd-b800-c317-532a" name="Warp Charge">1</characteristic>
                    <characteristic typeId="f04c-a782-d794-ddad" name="Power Category">Blessing</characteristic>
                    <characteristic typeId="fd64-cbc4-94de-24cc" name="Range">24&quot;</characteristic>
                    <characteristic typeId="ad96-dfa4-b4ed-656d" name="Details">A single friendly unit adds 1 to their Strength characteristic and gains the Rage special rule.</characteristic>
                  </characteristics>
                </profile>
                <profile typeId="ae70-4738-0161-bec0" typeName="Psychic Power" id="ffc9-1422-d298-66c0" name="Mental Onslaught" hidden="false">
                  <characteristics>
                    <characteristic typeId="5ffd-b800-c317-532a" name="Warp Charge">2</characteristic>
                    <characteristic typeId="f04c-a782-d794-ddad" name="Power Category">Focussed Witchfire</characteristic>
                    <characteristic typeId="fd64-cbc4-94de-24cc" name="Range">24&quot;</characteristic>
                    <characteristic typeId="ad96-dfa4-b4ed-656d" name="Details">Both the Psyker and the target model roll a dice and add their Leadership value. If the scores are drawn, the target model suffers a -3 penalty to its Initiative until the end of the following turn. If the Pskyer&apos;s score is higher, the target also suffers a number of Wounds equal to the difference between the scores. No armour or cover saves are allowed against these Wounds.</characteristic>
                  </characteristics>
                </profile>
                <profile typeId="ae70-4738-0161-bec0" typeName="Psychic Power" id="abfb-2041-7d30-355a" name="Mind Control" hidden="false">
                  <characteristics>
                    <characteristic typeId="5ffd-b800-c317-532a" name="Warp Charge">2</characteristic>
                    <characteristic typeId="f04c-a782-d794-ddad" name="Power Category">Focussed Witchfire</characteristic>
                    <characteristic typeId="fd64-cbc4-94de-24cc" name="Range">24&quot;</characteristic>
                    <characteristic typeId="ad96-dfa4-b4ed-656d" name="Details">A single non-vehicle model that is not locked in combat immediately makes a shooting attack exactly as if it were one of your own models. The model cannot make an attack that would cause it to hit itself or its own unit in any way. After resolving the shooting attack, the mind-controlled model immediately reverts to the owning player&apos;s control.</characteristic>
                  </characteristics>
                </profile>
                <profile typeId="ae70-4738-0161-bec0" typeName="Psychic Power" id="f3ef-1c17-2621-a4da" name="Telepathic Summons" hidden="false">
                  <characteristics>
                    <characteristic typeId="5ffd-b800-c317-532a" name="Warp Charge">2 or 3</characteristic>
                    <characteristic typeId="f04c-a782-d794-ddad" name="Power Category">Conjuration</characteristic>
                    <characteristic typeId="fd64-cbc4-94de-24cc" name="Range"/>
                    <characteristic typeId="ad96-dfa4-b4ed-656d" name="Details">Each time this psychic power is used, choose whether it will have Warp Charge 2 or 3. The choice must be made before the Psychic test is taken.  Warp Charge 2: A single unit of 5 Acolyte Hybrids, 5 Hybrid Metamorphs, or 10 Neophyte Hybrids (your choice).  Warp Charge 3: A single unit of 10 Acolyte Hybrids, 10 Hybrid Metamorphs, 4 Abberants, 8 Purestrain Genestealers, or 20 Neophyte Hybrids (your choice).  In any case, these unit can be equipped with any upgrades listed on their datasheet, but they cannot take any extra models or take a Dedicated Transport. These units always arrive using the Cult Ambush special rule instead of arriving via Deep Strike.</characteristic>
                  </characteristics>
                </profile>
              </profiles>
              <infoLinks>
                <infoLink id="609b-c626-d126-9ad4" name="Rage" hidden="false" targetId="3ac5-a550-39f8-f28a" type="rule"/>
                <infoLink id="8642-fed2-d2ec-46ec" name="Relentless" hidden="false" targetId="7674-690c-ab59-1444" type="rule"/>
                <infoLink id="69a7-df41-2d59-7237" name="Fleet" hidden="false" targetId="39c6-1f20-a156-47f4" type="rule"/>
              </infoLinks>
              <costs>
                <cost typeId="points" name="pts" value="0"/>
              </costs>
            </selectionEntry>
          </selectionEntries>
          <entryLinks>
            <entryLink id="5c2d-c597-51af-e9a3" hidden="false" targetId="7b9c-cc71-5fb2-f287" type="selectionEntry" name="Discipline: Biomancy"/>
            <entryLink id="e728-00c3-e284-39ea" hidden="false" targetId="f3dd-c529-d047-3c68" type="selectionEntry" name="Discipline: Telepathy"/>

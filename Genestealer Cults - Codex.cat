      <profiles>
        <profile typeId="d5f97c0b-9fc9-478d-aa34-a7c414d3ea48" id="4f9b-5b8f-62e8-dba7" name="Dagger of the Swift Sacrifice" publicationId="f840-ed73-pubd1e1" page="101" hidden="false">
          <characteristics>

      </constraints>
      <costs>
        <cost typeId="points" name="pts" value="15"/>
      </costs>
    </selectionEntry>
    <selectionEntry id="39d7-8363-ea30-25ee" name="Deliverance Broodsurge" hidden="false" collective="false" type="upgrade">
      <rules>
        <rule id="93a5-9988-9f17-46b9" name="Reckless Fanaticism" publicationId="f840-ed73-pubd1e1" page="87" hidden="false">
          <description>All units of Neophyte Hybrids from a Deliverance Broodsurge must begin the game embarked upon their Goliath Trucks. These units can disembark even if their vehicle moved at Cruising Speed, though each model that does so must take a Dangerous Terrain test.</description>
        </rule>
        <rule id="8c54-831a-4599-e390" name="Perfervid Crew" publicationId="f840-ed73-pubd1e1" page="87" hidden="false">
          <description>Each time a vehicle from this Formation suffers a Crew Stunned or Crew Shaken result, that result is ignored (though the vehicle still loses a Hull Point).</description>
        </rule>
      </rules>
      <selectionEntryGroups>

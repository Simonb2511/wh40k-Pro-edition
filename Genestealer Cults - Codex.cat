    <selectionEntry id="0f25-d656-380c-3540" name="Ghosar Quintus Broodkin" hidden="false" collective="false" type="unit">
      <rules>
        <rule id="2431-484a-c62f-dc0f" name="Ambush the Unhallowed" publicationId="f840-ed73-pubd1e7564" hidden="false">
          <description>All Ghosar Quintus Broodkin units that deploy using the Infiltrate USR have the Shrouded USR until the start of their second game turn, and can attempt to charge on their first turn.
In addition, when Patriarch Ghosar and the Purestrain Princelings deploy using their Infiltrate USR, they can be set up anywhere on the table that is more than 1&quot; from any enemy unit, whether deployed units can draw a line of sight to them or not (Patriarch Ghosar cannot do this if joined to a unit, unless that unit is the Purestrain Princelings).</description>
        </rule>
        <rule id="2bfa-a844-5e76-5f0c" name="Broodmind Telepathy" publicationId="f840-ed73-pubd1e7564" hidden="false">
          <description>Whilst Patriarch Ghosar is alive, all Ghosar Quintus Broodkin models have the Fearless and Adamantium Will USRs.</description>
        </rule>
      </rules>
      <infoLinks>
        <infoLink id="415e-767b-90b6-a3c0" hidden="false" targetId="0b11-a0ff-f0ba-5341" type="rule" name="Infiltrate"/>
        <infoLink id="8813-fdf5-8ee7-20a3" hidden="false" targetId="2ee4-4ad5-04de-d3e2" type="rule" name="Stealth"/>
      </infoLinks>
      <selectionEntries>
        <selectionEntry id="2026-afde-ef3b-84ef" name="Patriarch Ghosar" publicationId="f840-ed73-pubd1e7564" hidden="false" collective="false" type="model">
          <infoLinks>
            <infoLink id="f571-4524-1b00-ee95" hidden="false" targetId="04b3-5619-9034-b1d9" type="profile" name="Patriarch Ghosar"/>
            <infoLink id="357d-85bf-df76-622b" hidden="false" targetId="2ee4-4ad5-04de-d3e2" type="rule" name="Stealth"/>
